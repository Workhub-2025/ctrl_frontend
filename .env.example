# Environment variables for ctrl_frontend (Next.js 15)
# Copy this file to .env.local and fill in the actual values

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# ── NextAuth ─────────────────────────────────────────────────────────────────
# NEXTAUTH_URL must match the exact origin used in the browser.
# Production: https://your-frontend.pages.dev
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
# Must match JWT_SECRET in ctrl_backend .env (used to verify Strapi-issued JWTs)
JWT_SECRET=your-jwt-secret-here

# ── Strapi backend URLs ───────────────────────────────────────────────────────
# STRAPI_API_URL       — server-side only (SSR / API routes).
#                        In Docker: http://strapi:1337/api
#                        In development: http://127.0.0.1:1337/api
STRAPI_API_URL=http://127.0.0.1:1337/api
# NEXT_PUBLIC_STRAPI_API_URL — exposed to the browser (client components).
#                              Must be a public URL in production.
NEXT_PUBLIC_STRAPI_API_URL=http://127.0.0.1:1337/api

# ── Strapi API tokens ─────────────────────────────────────────────────────────
# Full-access token — used for admin operations (server-side only, never NEXT_PUBLIC_).
# Generate in Strapi Admin → Settings → API Tokens.
STRAPI_API_FULL_ACCESS_TOKEN=your-strapi-full-access-token-here
# Read-only token — used for public/low-privilege reads (server-side only).
STRAPI_API_READONLY_TOKEN=your-strapi-readonly-token-here

# ── Deployment flags ─────────────────────────────────────────────────────────
# Set to "true" when deploying to Cloudflare Pages.
# Enables static export (output: 'export') and disables image optimisation.
# CLOUDFLARE_PAGES=true
