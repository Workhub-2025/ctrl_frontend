# Environment variables for deployment
# Copy this file to .env.local and fill in the actual values

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000  # For production: https://your-frontend.pages.dev
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Strapi Backend Configuration
STRAPI_API_URL=http://localhost:1337/api  # For production: https://your-backend-app.ondigitalocean.app/api
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337/api  # For production: https://your-backend-app.ondigitalocean.app/api

# Additional API Configuration
NEXT_PUBLIC_API_URL=http://localhost:1337  # For production: https://your-backend-app.ondigitalocean.app

# OAuth Providers (if using Google/GitHub etc.)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Firebase (if using Firebase services)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# Deployment flags
CLOUDFLARE_PAGES=true  # Set to true only for Cloudflare Pages deployment

# Database (if using different environment for NextAuth)
# DATABASE_URL=postgresql://username:password@localhost:5432/your_database
